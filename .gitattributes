# Normalize line endings across platforms
* text=auto eol=lf

*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.jsonl text eol=lf

# Generated, large-ish data: keep but treat as data
rag/corpus.jsonl linguist-generated=true
data/problems.json linguist-generated=true
